<!DOCTYPE html>
<html lang="es">
    <head>
        <meta chartset="UTF-8">

        <title>Consulta de Empleados</title>

        <link rel="stylesheet" href="/css/estilos.css">

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body>
        <header class="bg-dark text-white py-4">
            <div class="container">
                <h1 class="h3 mb-1">Empresa</h1>
                <p class="mb-3 text-white-50">Consulta de empleados</p>
            </div>
        </header>

        <main>
            <div class="container py-5">
                <div class="border-1 p-3">
                    <form action="/consulta" method="post">
                        <div class="mb-3">
                            <label for="cargo" class="form-label">Cargo</label>
                            <input id="cargo" name="cargo" type="text" class="form-control" value="<%= cargo %>">
                        </div>

                        <div class="mb-3">
                            <label for="sueldoMinimo" class="form-label">Sueldo Mínimo</label>
                            <input id="sueldoMinimo" name="sueldoMinimo" type="number" min="0" class="form-control" value="<%= sueldoMinimo %>">
                        </div>
                        <div class="d-flex mb-3">
                            <button type="submit" class="btn btn-primary w-100">Consultar</button>
                        </div>
                        <% if (mensaje) { %>
                            <div class="alert alert-warning">
                                <%= mensaje %>
                            </div>
                        <% } %>

                        <% if (empleados.length > 0) { %>
                        
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Nombre</th>
                                            <th>Cargo</th>
                                            <th>Sueldo</th>           
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% empleados.forEach(empleado => { %>
                                            <tr>
                                                <td><%= empleado.id %></td>
                                                <td><%= empleado.nombre %></td>
                                                <td><%= empleado.cargo %></td>
                                                <td><%= empleado.sueldo %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                                <p class="text-muted mb-3">Registros: <%= empleados.length %></p>
                            </div>
                        <% } %>
                    </form>
                </div>
            </div>
        </main>
    </body>
</html>